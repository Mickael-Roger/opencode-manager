# Per-workspace image: adds the host user (UID/GID) on top of the resolved base
# image so files written into the bind-mounted home keep host ownership.
# Passwordless sudo is granted to ALL users in the base image (a numeric
# --user UID:GID loads no supplementary groups, so a sudo-group rule would never
# match the live process), so no group membership is needed here.
ARG BASE_IMAGE=docker.io/mroger78/ocm-base:latest
FROM ${BASE_IMAGE}

ARG UID
ARG GID

RUN set -eux; if getent group ${GID}; then group_name=$(getent group ${GID} | cut -d: -f1); else groupadd -g ${GID} debian && group_name=debian; fi; if getent passwd ${UID}; then user_name=$(getent passwd ${UID} | cut -d: -f1); usermod -d /home/debian -s /bin/bash ${user_name}; else useradd -m -u ${UID} -g ${GID} -s /bin/bash debian; user_name=debian; fi; mkdir -p /home/debian/workspace && chown -R ${UID}:${GID} /home/debian
WORKDIR /home/debian/workspace
