#!/bin/sh
# Attach wrapper. The container's main process is a persistent `opencode serve`;
# attaching runs a TUI client against it over HTTP. Ctrl-C exits only the client,
# leaving the server running. Wait for the server to listen, then attach to the
# last session if one exists, otherwise start a fresh session.

# The server binds this workspace's own assigned port (OCM_OPENCODE_PORT); there
# is no shared default, so connecting to a fallback port could reach a different
# workspace under host networking. A missing value is a manager bug — fail loudly.
if [ -z "$OCM_OPENCODE_PORT" ]; then
  echo "opencode-manager: OCM_OPENCODE_PORT is not set" >&2
  exit 1
fi
url="http://127.0.0.1:${OCM_OPENCODE_PORT}"
dir="/home/debian/workspace"
i=0
while [ "$i" -lt 150 ]; do
  curl -sf -o /dev/null "$url/session" && break
  i=$((i+1)); sleep 0.2
done
count=$(curl -sf "$url/session" | jq 'length' 2>/dev/null || echo 0)
if [ "${count:-0}" -gt 0 ] 2>/dev/null; then
  exec opencode attach "$url" --dir "$dir" -c
fi
exec opencode attach "$url" --dir "$dir"
