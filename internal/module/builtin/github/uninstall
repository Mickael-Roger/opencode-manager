#!/bin/sh
set -e

if [ -f "$HOME/.env" ]; then
  tmp="$(mktemp)"
  grep -vE '^export (GH_TOKEN|GITHUB_TOKEN)=' "$HOME/.env" > "$tmp" 2>/dev/null || true
  mv "$tmp" "$HOME/.env"
fi

rm -f "$HOME/.git-credentials"
git config --global --unset credential.helper 2>/dev/null || true

echo "github token removed"
