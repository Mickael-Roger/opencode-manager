#!/bin/sh
# Removes only this endpoint's section from ~/.ovh.conf, leaving other endpoints,
# the [default] pointer, and the ovhcloud binary in place (matching how other
# modules leave system tools).
set -e

: "${OCM_PROFILE:=ovh-eu}"

cfg="$HOME/.ovh.conf"
[ -f "$cfg" ] || exit 0

awk -v section="[$OCM_PROFILE]" '
  $0 == section { skip = 1; next }
  /^\[/ { skip = 0 }
  !skip { print }
' "$cfg" >"$cfg.tmp"
mv "$cfg.tmp" "$cfg"
chmod 600 "$cfg"

echo "ovh endpoint '$OCM_PROFILE' removed"
