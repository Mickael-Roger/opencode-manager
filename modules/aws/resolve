#!/bin/sh
# Host-side resolve hook: given the imported profile name ($OCM_PROFILE), read
# its static credentials from the host ~/.aws files and emit them as install
# values, so an imported instance stores only the profile name in the manifest
# while the real keys are pulled from the host on every install/reconcile.
#
# Runs on the host (where ~/.aws lives) before the container install. For a
# manually-added profile (one not present on the host) it emits nothing, leaving
# the values typed into the form in place. Emits only when both an access key and
# secret key are found, so SSO/role profiles are skipped rather than half-written.
set -e

[ -n "$OCM_PROFILE" ] || exit 0

cred="${AWS_SHARED_CREDENTIALS_FILE:-$HOME/.aws/credentials}"
conf="${AWS_CONFIG_FILE:-$HOME/.aws/config}"

# get_field FILE SECTION KEY prints the value of KEY within the [SECTION] block.
get_field() {
  [ -f "$1" ] || return 0
  awk -v section="$2" -v key="$3" '
    /^[[:space:]]*\[/ {
      s = $0
      sub(/^[^[]*\[/, "", s)
      sub(/\].*/, "", s)
      sub(/^[[:space:]]+/, "", s)
      sub(/[[:space:]]+$/, "", s)
      cur = s
      next
    }
    cur == section && match($0, "^[[:space:]]*" key "[[:space:]]*=") {
      v = $0
      sub(/^[^=]*=[[:space:]]*/, "", v)
      sub(/[[:space:]]+$/, "", v)
      print v
      exit
    }
  ' "$1"
}

ak="$(get_field "$cred" "$OCM_PROFILE" aws_access_key_id)"
sk="$(get_field "$cred" "$OCM_PROFILE" aws_secret_access_key)"

# Region lives in ~/.aws/config, under [default] or [profile NAME].
if [ "$OCM_PROFILE" = "default" ]; then
  region_section="default"
else
  region_section="profile $OCM_PROFILE"
fi
region="$(get_field "$conf" "$region_section" region)"

[ -n "$ak" ] && [ -n "$sk" ] || exit 0

printf 'access_key=%s\n' "$ak"
printf 'secret_key=%s\n' "$sk"
[ -n "$region" ] && printf 'region=%s\n' "$region"
exit 0
