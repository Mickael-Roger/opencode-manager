#!/bin/sh
# Runs inside the workspace container. Installs kubectl (if missing) and merges
# the single context produced by the host resolve hook ($OCM_KUBECONFIG, base64)
# into ~/.kube/config. Because this runs once per selected context, kubectl is
# installed as soon as the first context is added. Idempotent: the kubectl install
# is guarded and merging the same context again just overwrites that entry, so
# reconcile can re-run this safely.
set -e

if ! command -v kubectl >/dev/null 2>&1; then
  if ! command -v curl >/dev/null 2>&1; then
    sudo apt-get update
    sudo apt-get install -y --no-install-recommends curl ca-certificates
  fi
  case "$(dpkg --print-architecture 2>/dev/null || echo amd64)" in
    arm64 | aarch64) karch=arm64 ;;
    *) karch=amd64 ;;
  esac
  ver="$(curl -fsSL https://dl.k8s.io/release/stable.txt)"
  curl -fsSL "https://dl.k8s.io/release/${ver}/bin/linux/${karch}/kubectl" -o /tmp/kubectl
  sudo install -m 0755 /tmp/kubectl /usr/local/bin/kubectl
  rm -f /tmp/kubectl
fi

mkdir -p "$HOME/.kube"
chmod 700 "$HOME/.kube"

if [ -z "$OCM_KUBECONFIG" ]; then
  echo "kubernetes: context '${OCM_CONTEXT:-?}' could not be resolved from the host (nothing written)"
  exit 0
fi

cfg="$HOME/.kube/config"
new="$(mktemp)"
printf '%s' "$OCM_KUBECONFIG" | base64 -d >"$new"

if [ -s "$cfg" ]; then
  # Merge the incoming context with the existing config (later entries win, so a
  # repeated import overwrites rather than duplicates).
  merged="$(mktemp)"
  KUBECONFIG="$cfg:$new" kubectl config view --flatten >"$merged"
  mv "$merged" "$cfg"
  rm -f "$new"
else
  mv "$new" "$cfg"
fi
chmod 600 "$cfg"

echo "kubernetes context imported: $OCM_CONTEXT"
