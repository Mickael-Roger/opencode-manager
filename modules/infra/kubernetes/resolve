#!/bin/sh
# Host-side resolve hook: turn the selected context name ($OCM_CONTEXT) into a
# self-contained, single-context kubeconfig and emit it as a base64 value for the
# container install script. Runs on the host, where ~/.kube/config lives; the
# workspace container never sees the full host config. The context is extracted
# with its credentials inlined (--minify --flatten). Prints "kubeconfig=<base64>".
set -e

[ -n "$OCM_CONTEXT" ] || exit 0
command -v kubectl >/dev/null 2>&1 || exit 0

cfg="$(kubectl config view --minify --flatten --context "$OCM_CONTEXT" 2>/dev/null)" || exit 0
[ -n "$cfg" ] || exit 0

printf 'kubeconfig=%s\n' "$(printf '%s' "$cfg" | base64 | tr -d '\n')"
