#!/bin/sh
# Configures the git identity from the values resolved off the host and clones the
# requested repository into the workspace home directory. Idempotent: identity is
# (re)written only for values the host actually provides, and a repo whose target
# directory already exists is left untouched, so reconcile never re-clones or
# clobbers local work.
set -e

# Install git if missing (needed for both the config below and cloning).
if ! command -v git >/dev/null 2>&1; then
  sudo apt-get update
  sudo apt-get install -y --no-install-recommends git
fi

# Identity comes from the host via the resolve hook; set only what the host has,
# otherwise leave git to its own defaults rather than writing empty values.
if [ -n "$OCM_NAME" ]; then
  git config --global user.name "$OCM_NAME"
fi
if [ -n "$OCM_EMAIL" ]; then
  git config --global user.email "$OCM_EMAIL"
fi
if [ -n "$OCM_NAME" ] || [ -n "$OCM_EMAIL" ]; then
  echo "git identity configured: ${OCM_NAME:-unset} <${OCM_EMAIL:-unset}>"
fi

# No repo to clone (e.g. an identity-only legacy entry): identity is configured
# above, nothing left to do.
if [ -z "$OCM_REPO" ]; then
  echo "no repository specified; git identity configured only"
  exit 0
fi

# is_ssh_url reports whether a clone URL goes over SSH (ssh:// or scp-like
# git@host:path), as opposed to http(s). Such clones need the OpenSSH client.
is_ssh_url() {
  case "$1" in
    ssh://*) return 0 ;;
    *://*) return 1 ;;
    *@*:*) return 0 ;;
    *) return 1 ;;
  esac
}

# ensure_ssh_client installs the OpenSSH client the first time an SSH URL is
# cloned. The keys/host config themselves come from the ssh module; here we only
# make sure the `ssh` binary git shells out to actually exists.
ensure_ssh_client() {
  command -v ssh >/dev/null 2>&1 && return 0
  sudo apt-get update
  sudo apt-get install -y --no-install-recommends openssh-client
}

name="$(basename "$OCM_REPO" .git)"
dest="$HOME/$name"
if [ -e "$dest" ]; then
  echo "git repo '$name' already present, skipping"
  exit 0
fi

is_ssh_url "$OCM_REPO" && ensure_ssh_client
git clone "$OCM_REPO" "$dest"
echo "git repo cloned: $OCM_REPO -> $dest"
