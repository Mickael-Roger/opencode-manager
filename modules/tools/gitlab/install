#!/bin/sh
# Runs inside the workspace container. Installs the GitLab CLI (glab) from the
# latest official release (no apt repo exists; the release binary is fetched for
# this arch) and, when the user opted in, drops this host's glab configuration
# (shipped base64-encoded by the resolve hook) into place so glab is signed in to
# the same GitLab instance(s). Idempotent: the glab install is guarded and the
# config is overwritten, so reconcile can re-run this safely.
set -e

if ! command -v glab >/dev/null 2>&1; then
  for bin in curl jq; do
    if ! command -v "$bin" >/dev/null 2>&1; then
      sudo apt-get update
      sudo apt-get install -y --no-install-recommends curl jq ca-certificates
      break
    fi
  done

  case "$(dpkg --print-architecture 2>/dev/null || echo amd64)" in
    arm64 | aarch64) garch=arm64 ;;
    *) garch=amd64 ;;
  esac

  # Resolve the linux/<arch> tarball URL from the latest release's asset links.
  api="https://gitlab.com/api/v4/projects/gitlab-org%2Fcli/releases/permalink/latest"
  url="$(curl -fsSL "$api" \
    | jq -r --arg a "linux_${garch}.tar.gz" \
      '.assets.links[] | select(.name | endswith($a)) | .url' | head -n1)"
  if [ -z "$url" ]; then
    echo "gitlab: could not find a glab release asset for linux_${garch}" >&2
    exit 1
  fi

  tmp="$(mktemp -d)"
  curl -fsSL "$url" -o "$tmp/glab.tar.gz"
  tar -C "$tmp" -xzf "$tmp/glab.tar.gz"
  glab_bin="$(find "$tmp" -type f -name glab | head -n1)"
  if [ -z "$glab_bin" ]; then
    echo "gitlab: glab binary not found in the release archive" >&2
    rm -rf "$tmp"
    exit 1
  fi
  sudo install -m 0755 "$glab_bin" /usr/local/bin/glab
  rm -rf "$tmp"
fi

echo "glab installed: $(glab --version | head -n1)"

# Import the host's glab configuration when provided. $OCM_CONFIG_B64 is the
# host's ~/.config/glab-cli/config.yml, base64-encoded by the resolve hook; it
# carries the hosts and tokens that sign glab in, and is never persisted to the
# manifest.
if [ -n "$OCM_CONFIG_B64" ]; then
  mkdir -p "$HOME/.config/glab-cli"
  printf '%s' "$OCM_CONFIG_B64" | base64 -d > "$HOME/.config/glab-cli/config.yml"
  chmod 600 "$HOME/.config/glab-cli/config.yml"
  echo "glab configured from this host's glab configuration"
else
  echo "glab installed without imported configuration"
fi
