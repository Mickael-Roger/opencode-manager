#!/bin/sh
# Host-side resolve hook: when the user opts in, copy this host's glab CLI
# configuration into the workspace so the container's glab is signed in to the
# same GitLab instance(s). It reads the host's config.yml (which holds the hosts
# and their tokens) and emits it base64-encoded as a single `config_b64` value;
# the install script decodes it into the workspace's glab config. Nothing is
# typed and nothing is persisted to the manifest — resolve output is not stored,
# and it runs on every install/reconcile, so the imported config tracks the
# host's current auth.
#
# Stays silent and exits 0 when import is off or the host has no glab config,
# leaving the workspace's glab unconfigured rather than failing.
set -e

case "$OCM_IMPORT_CONFIG" in
  yes | true | 1 | on) ;;
  *) exit 0 ;;
esac

cfg="${GLAB_CONFIG_DIR:-$HOME/.config/glab-cli}/config.yml"
[ -f "$cfg" ] || exit 0

# base64 with newlines stripped: portable across GNU (wraps at 76 columns) and
# BSD/macOS, decoded as one line by the container's `base64 -d`.
b64="$(base64 < "$cfg" | tr -d '\n')"
[ -n "$b64" ] && printf 'config_b64=%s\n' "$b64"
exit 0
